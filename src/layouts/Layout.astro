---
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
}
const {
  title = "Agenda Cinéma des Enfants",
  description = "Les meilleurs films pour enfants au cinéma – sélection, synopses et séances.",
} = Astro.props;
---

<!doctype html>
<html lang="fr">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <title>{title}</title>
    <link rel="icon" type="image/png" href="/images/logo.png" />
  </head>
  <body>
    <slot />
  </body>
</html>
