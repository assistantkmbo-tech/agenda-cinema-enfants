---
import { getCollection, getEntry } from 'astro:content';
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import FilmCard from '../components/FilmCard.astro';

const allFilms = await getCollection('films');
const ordreEntry = await getEntry('settings', 'ordre').catch(() => null);
const siteEntry  = await getEntry('settings', 'site').catch(() => null);

// Ordre depuis settings/ordre.json, sinon fallback sur le champ order
const ordreList: string[] = ordreEntry?.data?.films ?? [];
const filmMap = Object.fromEntries(allFilms.map(f => [f.id, f]));

const sorted = ordreList.length
  ? ordreList.map(slug => filmMap[slug]).filter(Boolean)
  : allFilms.sort((a, b) => a.data.order - b.data.order);

// Auto-promotion basée sur releaseDate au moment du build
const today = new Date();
today.setHours(0, 0, 0, 0);

function effectiveStatus(film: typeof sorted[0]) {
  if (film.data.status === 'archive') return 'archive';
  if (film.data.status === 'bientot' && film.data.releaseDate) {
    if (new Date(film.data.releaseDate) <= today) return 'en_salle';
  }
  return film.data.status;
}

function getDateLabel(film: typeof sorted[0]) {
  if (effectiveStatus(film) === 'en_salle') return 'ACTUELLEMENT AU CINÉMA';
  if (film.data.releaseDate) {
    const date = new Date(film.data.releaseDate + 'T12:00:00');
    return date.toLocaleDateString('fr-FR', { day: 'numeric', month: 'long' }).toUpperCase();
  }
  return 'BIENTÔT';
}

const enSalle = sorted.filter(f => effectiveStatus(f) === 'en_salle');
const bientot = sorted.filter(f => effectiveStatus(f) === 'bientot');

const heroImage = siteEntry?.data?.heroImage ?? enSalle[0]?.data.poster;

const introTitle    = siteEntry?.data?.introTitle    ?? 'LES FILMS POUR ENFANTS AU CINÉMA';
const introSubtitle = siteEntry?.data?.introSubtitle ?? 'Inscrivez-vous à notre newsletter et soyez au courant des plus belles sorties pour vos enfants.';
const newsletterUrl = siteEntry?.data?.newsletterUrl ?? '#';
const soonTitle     = siteEntry?.data?.soonTitle     ?? 'Bientôt au cinéma';
---

<Layout>

  <Header newsletterUrl={newsletterUrl} />

  <main
    style={heroImage ? `background-image: url('${heroImage}'); background-position: unset;` : ''}
  >

    <!-- INTRO -->
    <section id="intro" class="section-intro">
      <div class="container">
        <h1 class="section-intro__title">{introTitle}</h1>
        <h2 class="section-intro__subtitle">{introSubtitle}</h2>
      </div>
      <div class="container section-intro__inner">
        <div class="section-intro__infos"></div>
      </div>
    </section>

    <!-- FILMS À L'AFFICHE -->
    <section id="film-affiche" class="filmslist">
      <div class="container">
        <div class="films">
          <div class="films-content">

            {enSalle.map(film => (
              <FilmCard
                title={film.data.title}
                director={film.data.director}
                duration={film.data.duration}
                ageMin={film.data.ageMin}
                synopsis={film.data.synopsis}
                dateLabel={getDateLabel(film)}
                status={effectiveStatus(film) as 'en_salle' | 'bientot'}
                coupDeCoeur={film.data.coupDeCoeur}
                poster={film.data.poster}
                allocineUrl={film.data.allocineUrl}
                trailerUrl={film.data.trailerUrl}
                seancesUrl={film.data.seancesUrl}
              />
            ))}

          </div>
        </div>
      </div>
    </section>

    <!-- BIENTÔT AU CINÉMA -->
    <section id="soon" class="soon">
      <div class="container">
        <h1 class="title">{soonTitle}</h1>
        <div class="movies">
          <div class="content">
            {bientot.map(film => (
              <a
                href={film.data.allocineUrl ?? film.data.seancesUrl ?? '#'}
                target="_blank"
                rel="noopener"
              >
                <div class="item">
                  <span class="date">{film.data.dateLabel}</span>
                  <img
                    class="poster"
                    src={film.data.poster}
                    alt={`Affiche : ${film.data.title}`}
                    loading="lazy"
                  />
                </div>
              </a>
            ))}
          </div>
        </div>
      </div>
    </section>

  </main>

</Layout>
